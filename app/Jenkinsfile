pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    timestamps()
  }

  parameters {
    string(
      name: 'IMAGE_TAG',
      defaultValue: '',
      description: 'Optional image tag. Empty uses the Jenkins build number and Git SHA.'
    )
    booleanParam(
      name: 'PUSH_LATEST',
      defaultValue: true,
      description: 'Also push the image as latest.'
    )
    booleanParam(
      name: 'DEPLOY',
      defaultValue: true,
      description: 'Update the ECS service after pushing the image.'
    )
  }

  environment {
    AWS_REGION = 'us-east-1'
    AWS_DEFAULT_REGION = 'us-east-1'

    APP_DIR = 'app'

    ECR_REPOSITORY = 'demo-fastapi'
    TASK_FAMILY = 'demo-fastapi'
    TASK_EXECUTION_ROLE_NAME = 'demo-ecs-task-execution'
    TASK_DEFINITION_TEMPLATE = 'app/task-definition.json'
    TASK_DEFINITION_RENDERED = 'task-definition-rendered.json'
    API_HEALTH_CHECK_PATH = '/health'

    ECS_CLUSTER = 'custom-ecs'
    ECS_SERVICE = 'demo-nginx'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Verify Jenkins Agent') {
      steps {
        sh '''
          set -eu

          missing_tools=""
          for tool in aws docker curl git; do
            if ! command -v "${tool}" >/dev/null 2>&1; then
              missing_tools="${missing_tools} ${tool}"
            fi
          done

          if [ -n "${missing_tools}" ]; then
            echo "Missing required command(s):${missing_tools}"
            echo "Install them on the Jenkins agent, or run this job on an agent image that includes them."
            exit 1
          fi

          aws --version
          docker --version
          curl --version
          git --version

          if ! docker info >/dev/null 2>&1; then
            echo "Docker is installed, but Jenkins cannot talk to the Docker daemon."
            echo "Start Docker on the agent, or give the Jenkins user permission to use Docker."
            exit 1
          fi
        '''
      }
    }

    stage('Resolve Image') {
      steps {
        script {
          env.GIT_SHA = sh(script: 'git rev-parse --short=12 HEAD', returnStdout: true).trim()

          def requestedTag = params.IMAGE_TAG.trim()
          env.IMAGE_TAG = requestedTag ? requestedTag : "${env.BUILD_NUMBER}-${env.GIT_SHA}"
        }

        sh 'echo "Deploying image tag: ${IMAGE_TAG}"'
      }
    }

    stage('Verify AWS and Login to ECR') {
      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding',
           credentialsId: 'aws-dev-credential',
           accessKeyVariable: 'AWS_ACCESS_KEY_ID',
           secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
        ]) {
          script {
            env.ECR_URI = sh(
              script: 'aws ecr describe-repositories --repository-names "${ECR_REPOSITORY}" --query "repositories[0].repositoryUri" --output text',
              returnStdout: true
            ).trim()
          }

          sh '''
            set +x
            aws sts get-caller-identity
            aws ecr get-login-password --region "${AWS_REGION}" | docker login --username AWS --password-stdin "${ECR_URI%/*}"
          '''
        }
      }
    }

    stage('Verify ECS Deployment Target') {
      when {
        expression { return params.DEPLOY }
      }

      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding',
           credentialsId: 'aws-dev-credential',
           accessKeyVariable: 'AWS_ACCESS_KEY_ID',
           secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
        ]) {
          sh '''
            set -eu

            cluster_status="$(aws ecs describe-clusters \
              --clusters "${ECS_CLUSTER}" \
              --query "clusters[0].status" \
              --output text)"

            if [ "${cluster_status}" != "ACTIVE" ]; then
              echo "ECS cluster ${ECS_CLUSTER} is not ACTIVE. Current status: ${cluster_status}"
              exit 1
            fi

            service_status="$(aws ecs describe-services \
              --cluster "${ECS_CLUSTER}" \
              --services "${ECS_SERVICE}" \
              --query "services[0].status" \
              --output text)"

            if [ "${service_status}" != "ACTIVE" ]; then
              echo "ECS service ${ECS_SERVICE} is not ACTIVE. Current status: ${service_status}"
              exit 1
            fi

            target_group_arn="$(aws ecs describe-services \
              --cluster "${ECS_CLUSTER}" \
              --services "${ECS_SERVICE}" \
              --query "services[0].loadBalancers[0].targetGroupArn" \
              --output text)"

            if [ -z "${target_group_arn}" ] || [ "${target_group_arn}" = "None" ]; then
              echo "ECS service ${ECS_SERVICE} is not attached to a target group."
              exit 1
            fi

            load_balancer_arn="$(aws elbv2 describe-target-groups \
              --target-group-arns "${target_group_arn}" \
              --query "TargetGroups[0].LoadBalancerArns[0]" \
              --output text)"

            if [ -z "${load_balancer_arn}" ] || [ "${load_balancer_arn}" = "None" ]; then
              echo "Target group ${target_group_arn} is not attached to a load balancer."
              exit 1
            fi

            alb_dns_name="$(aws elbv2 describe-load-balancers \
              --load-balancer-arns "${load_balancer_arn}" \
              --query "LoadBalancers[0].DNSName" \
              --output text)"

            echo "ECS deployment target is ready: http://${alb_dns_name}"
          '''
        }
      }
    }

    stage('Build Image') {
      steps {
        dir(env.APP_DIR) {
          sh '''
            docker build \
              --label "org.opencontainers.image.revision=${GIT_SHA}" \
              -t "${ECR_URI}:${IMAGE_TAG}" \
              -t "${ECR_URI}:latest" \
              .
          '''
        }
      }
    }

    stage('Push Image') {
      steps {
        sh '''
          docker push "${ECR_URI}:${IMAGE_TAG}"

          if [ "${PUSH_LATEST}" = "true" ]; then
            docker push "${ECR_URI}:latest"
          fi
        '''
      }
    }

    stage('Register Task Definition') {
      when {
        expression { return params.DEPLOY }
      }

      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding',
           credentialsId: 'aws-dev-credential',
           accessKeyVariable: 'AWS_ACCESS_KEY_ID',
           secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
        ]) {
          script {
            env.IMAGE_URI = "${env.ECR_URI}:${env.IMAGE_TAG}"
            env.AWS_ACCOUNT_ID = sh(
              script: 'aws sts get-caller-identity --query Account --output text',
              returnStdout: true
            ).trim()
            env.EXECUTION_ROLE_ARN = "arn:aws:iam::${env.AWS_ACCOUNT_ID}:role/${env.TASK_EXECUTION_ROLE_NAME}"

            def renderedTaskDefinition = readFile(env.TASK_DEFINITION_TEMPLATE)
            [
              '${AWS_REGION}': env.AWS_REGION,
              '${EXECUTION_ROLE_ARN}': env.EXECUTION_ROLE_ARN,
              '${IMAGE_URI}': env.IMAGE_URI,
              '${TASK_FAMILY}': env.TASK_FAMILY
            ].each { placeholder, value ->
              renderedTaskDefinition = renderedTaskDefinition.replace(placeholder, value)
            }

            if (renderedTaskDefinition.contains('${')) {
              error('Rendered task definition still contains an unresolved ${...} placeholder.')
            }

            writeFile file: env.TASK_DEFINITION_RENDERED, text: "${renderedTaskDefinition}\n"
            echo "Rendered task definition:\n${renderedTaskDefinition}"

            env.NEW_TASK_DEFINITION_ARN = sh(
              script: 'aws ecs register-task-definition --cli-input-json file://${TASK_DEFINITION_RENDERED} --query "taskDefinition.taskDefinitionArn" --output text',
              returnStdout: true
            ).trim()
          }

          sh 'echo "Registered task definition: ${NEW_TASK_DEFINITION_ARN}"'
        }
      }
    }

    stage('Update ECS Service') {
      when {
        expression { return params.DEPLOY }
      }

      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding',
           credentialsId: 'aws-dev-credential',
           accessKeyVariable: 'AWS_ACCESS_KEY_ID',
           secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
        ]) {
          sh '''
            aws ecs update-service \
              --cluster "${ECS_CLUSTER}" \
              --service "${ECS_SERVICE}" \
              --task-definition "${NEW_TASK_DEFINITION_ARN}"
          '''
        }
      }
    }

    stage('Wait for ECS') {
      when {
        expression { return params.DEPLOY }
      }

      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding',
           credentialsId: 'aws-dev-credential',
           accessKeyVariable: 'AWS_ACCESS_KEY_ID',
           secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
        ]) {
          sh 'aws ecs wait services-stable --cluster "${ECS_CLUSTER}" --services "${ECS_SERVICE}"'
        }
      }
    }

    stage('Smoke Test ALB') {
      when {
        expression { return params.DEPLOY }
      }

      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding',
           credentialsId: 'aws-dev-credential',
           accessKeyVariable: 'AWS_ACCESS_KEY_ID',
           secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
        ]) {
          script {
            env.ALB_DNS_NAME = sh(
              script: '''
                set -eu

                TARGET_GROUP_ARN="$(aws ecs describe-services \
                  --cluster "${ECS_CLUSTER}" \
                  --services "${ECS_SERVICE}" \
                  --query "services[0].loadBalancers[0].targetGroupArn" \
                  --output text)"

                LOAD_BALANCER_ARN="$(aws elbv2 describe-target-groups \
                  --target-group-arns "${TARGET_GROUP_ARN}" \
                  --query "TargetGroups[0].LoadBalancerArns[0]" \
                  --output text)"

                aws elbv2 describe-load-balancers \
                  --load-balancer-arns "${LOAD_BALANCER_ARN}" \
                  --query "LoadBalancers[0].DNSName" \
                  --output text
              ''',
              returnStdout: true
            ).trim()
          }

          sh '''
            ALB_URL="http://${ALB_DNS_NAME}"
            echo "App URL: ${ALB_URL}"

            attempt=1
            while [ "${attempt}" -le 12 ]; do
              if curl -fsS "${ALB_URL}${API_HEALTH_CHECK_PATH}"; then
                exit 0
              fi

              echo "Waiting for ALB health endpoint, attempt ${attempt}/12"
              sleep 10
              attempt=$((attempt + 1))
            done

            curl -fsS "${ALB_URL}${API_HEALTH_CHECK_PATH}"
          '''
        }
      }
    }
  }
}
