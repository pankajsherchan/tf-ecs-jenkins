pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    timestamps()
  }

  parameters {
    booleanParam(
      name: 'APPLY',
      defaultValue: false,
      description: 'Apply the Terraform plan after review.'
    )
    string(
      name: 'PROJECT_NAME',
      defaultValue: 'demo',
      description: 'Project name used as the first part of AWS resource names.'
    )
    string(
      name: 'ENV',
      defaultValue: 'dev',
      description: 'Deployment environment used in AWS resource names.'
    )
    string(
      name: 'APP_NAME',
      defaultValue: 'api',
      description: 'App container name to keep in the ECS service while changing infrastructure.'
    )
    string(
      name: 'APP_PORT',
      defaultValue: '8000',
      description: 'App container port to keep in the ECS service while changing infrastructure.'
    )
    string(
      name: 'APP_HEALTH_CHECK_PATH',
      defaultValue: '/health',
      description: 'Target group health check path to keep while changing infrastructure.'
    )
    string(
      name: 'APP_IMAGE_TAG',
      defaultValue: 'latest',
      description: 'Image tag to keep in the ECS task definition while changing infrastructure.'
    )
  }

  environment {
    AWS_REGION = 'us-east-1'
    AWS_DEFAULT_REGION = 'us-east-1'
    TF_IN_AUTOMATION = 'true'
    PLAN_FILE = 'infra.tfplan'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Verify AWS') {
      steps {
        withCredentials([
          [$class: 'AmazonWebServicesCredentialsBinding',
           credentialsId: 'aws-dev-credential',
           accessKeyVariable: 'AWS_ACCESS_KEY_ID',
           secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']
        ]) {
          sh '''
            set +x
            aws --version
            terraform version

            env | grep '^AWS_' | sed 's/=.*/=***MASKED***/'

            aws sts get-caller-identity
          '''
        }
      }
    }

    stage('Resolve Layout') {
      steps {
        script {
          env.TERRAFORM_DIR = fileExists('infra/1-providers.tf') ? 'infra' : '.'
        }
        sh 'echo "Terraform directory: ${TERRAFORM_DIR}"'
      }
    }

    stage('Terraform Init') {
      steps {
        dir(env.TERRAFORM_DIR) {
          withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
            credentialsId: 'aws-dev-credential',
            accessKeyVariable: 'AWS_ACCESS_KEY_ID',
            secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
          ]]) {
            sh '''
              rm -rf .terraform

              terraform init -input=false -reconfigure \
                -backend-config="key=demo_ecs/${AWS_REGION}/terraform.tfstate"
            '''
          }
        }
      }
    }

    stage('Terraform Check') {
      steps {
        dir(env.TERRAFORM_DIR) {
          sh 'terraform fmt -check -recursive'
          sh 'terraform validate'
        }
      }
    }

    stage('Terraform Plan') {
      steps {
        dir(env.TERRAFORM_DIR) {
          withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
            credentialsId: 'aws-dev-credential',
            accessKeyVariable: 'AWS_ACCESS_KEY_ID',
            secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
          ]]) {
            sh '''
              terraform plan -input=false -out="${PLAN_FILE}" \
                -var="project_name=${PROJECT_NAME}" \
                -var="environment=${ENV}" \
                -var="app_name=${APP_NAME}" \
                -var="app_port=${APP_PORT}" \
                -var="app_health_check_path=${APP_HEALTH_CHECK_PATH}" \
                -var="app_image_tag=${APP_IMAGE_TAG}"
            '''
          }
        }
      }
    }

    stage('Terraform Apply') {
      when {
        expression { return params.APPLY }
      }
      steps {
        dir(env.TERRAFORM_DIR) {
          withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
            credentialsId: 'aws-dev-credential',
            accessKeyVariable: 'AWS_ACCESS_KEY_ID',
            secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
          ]]) {
            sh 'terraform apply -input=false -auto-approve "${PLAN_FILE}"'
          }
        }
      }
    }
  }
}
